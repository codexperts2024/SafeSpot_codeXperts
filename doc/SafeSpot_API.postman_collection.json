{
  "info": {
    "_postman_id": "safespot-toronto-api",
    "name": "SafeSpot Toronto API",
    "description": "Backend API for SafeSpot Toronto — real-time extreme weather safety app. Hono.js + PostgreSQL sensor readings with alert history, humidex, location metadata, and alert levels.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "safespot-backend-bbn6.onrender.com"
    },
    {
      "key": "protocol",
      "value": "https"
    },
    {
      "key": "local_base_url",
      "value": "localhost:8000"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}://{{base_url}}/health",
              "protocol": "{{protocol}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"status\": \"ok\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "API Documentation",
      "item": [
        {
          "name": "OpenAPI Spec",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}://{{base_url}}/openapi.json",
              "protocol": "{{protocol}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "openapi.json"
              ]
            }
          },
          "response": [
            {
              "name": "OpenAPI 3.1 Spec",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"openapi\": \"3.1.0\",\n  \"info\": {\n    \"title\": \"SafeSpot Toronto — Sensor API\",\n    \"version\": \"1.0.0\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Swagger UI Docs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}://{{base_url}}/docs",
              "protocol": "{{protocol}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "docs"
              ]
            },
            "description": "Opens the Swagger UI interactive API documentation. Best viewed in a browser."
          }
        }
      ]
    },
    {
      "name": "Sensor Data",
      "description": "Endpoints for submitting and retrieving temperature sensor readings from the Raspberry Pi. Readings can include optional humidity and location metadata.",
      "item": [
        {
          "name": "Submit Sensor Reading",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"temperature\": 37.5,\n  \"humidity\": 68,\n  \"lat\": 43.6532,\n  \"lng\": -79.3832,\n  \"zone\": \"downtown\"\n}"
            },
            "url": {
              "raw": "{{protocol}}://{{base_url}}/api/sensors",
              "protocol": "{{protocol}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "sensors"
              ]
            },
            "description": "Receives a temperature reading from the Raspberry Pi sensor. Stores it with source: \"sensor\", calculates humidex when humidity is provided, evaluates alert level, and records alert history.\n\nRequired body fields:\n- temperature: number between -100 and 100\n\nOptional body fields:\n- humidity: number between 0 and 100\n- lat: number\n- lng: number\n- zone: string"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"status\": \"ok\"\n}"
            },
            {
              "name": "Validation Error",
              "status": "Bad Request",
              "code": 400,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"error\": \"Missing or invalid field: temperature\"\n}"
            }
          ]
        },
        {
          "name": "Get Latest Sensor Reading",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}://{{base_url}}/api/sensors",
              "protocol": "{{protocol}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "sensors"
              ]
            },
            "description": "Returns the most recent sensor reading. When no reading has been recorded, nullable empty-state fields are returned."
          },
          "response": [
            {
              "name": "With Data",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"id\": 1,\n  \"temperature\": 37.5,\n  \"humidity\": 68,\n  \"humidex\": 46.1,\n  \"timestamp\": \"2026-05-26T14:30:00.000Z\",\n  \"alert\": {\n    \"level\": \"danger\",\n    \"message\": \"Extreme Heat Warning - Find a Cool Space Now\"\n  }\n}"
            },
            {
              "name": "Empty Database",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"temperature\": null,\n  \"humidity\": null,\n  \"humidex\": null,\n  \"timestamp\": null,\n  \"alert\": null\n}"
            }
          ]
        },
        {
          "name": "List Sensor Readings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}://{{base_url}}/api/sensors?limit=25&from=2026-05-26T00:00:00.000Z&to=2026-05-27T00:00:00.000Z",
              "protocol": "{{protocol}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "sensors"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "25",
                  "description": "Optional number of newest-first readings to return. Providing limit/from/to switches this endpoint to list mode."
                },
                {
                  "key": "from",
                  "value": "2026-05-26T00:00:00.000Z",
                  "description": "Optional ISO 8601 start timestamp."
                },
                {
                  "key": "to",
                  "value": "2026-05-27T00:00:00.000Z",
                  "description": "Optional ISO 8601 end timestamp."
                }
              ]
            },
            "description": "Returns newest-first historical sensor readings when any of limit, from, or to is provided."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "[\n  {\n    \"id\": 1,\n    \"temperature\": 37.5,\n    \"humidity\": 68,\n    \"humidex\": 46.1,\n    \"timestamp\": \"2026-05-26T14:30:00.000Z\",\n    \"alert\": {\n      \"level\": \"danger\",\n      \"message\": \"Extreme Heat Warning - Find a Cool Space Now\"\n    }\n  }\n]"
            },
            {
              "name": "Invalid Query",
              "status": "Bad Request",
              "code": 400,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"error\": \"Invalid limit\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Alerts",
      "description": "Endpoints for retrieving recorded alert history. Alert records are returned newest-first and support optional date, level, zone, and limit filters.",
      "item": [
        {
          "name": "List Alerts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}://{{base_url}}/api/alerts?limit=25&level=danger&zone=downtown&from=2026-05-26T00:00:00.000Z&to=2026-05-27T00:00:00.000Z",
              "protocol": "{{protocol}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "alerts"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "25",
                  "description": "Optional number of newest-first alerts to return."
                },
                {
                  "key": "level",
                  "value": "danger",
                  "description": "Optional alert level: safe, caution, danger, or extreme."
                },
                {
                  "key": "zone",
                  "value": "downtown",
                  "description": "Optional zone filter."
                },
                {
                  "key": "from",
                  "value": "2026-05-26T00:00:00.000Z",
                  "description": "Optional ISO 8601 start timestamp."
                },
                {
                  "key": "to",
                  "value": "2026-05-27T00:00:00.000Z",
                  "description": "Optional ISO 8601 end timestamp."
                }
              ]
            },
            "description": "Returns alert log rows from PostgreSQL. If no filters are provided, defaults to the last 24 hours."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "[\n  {\n    \"id\": 1,\n    \"timestamp\": \"2026-05-26T14:30:00.000Z\",\n    \"temperature\": 37.5,\n    \"humidex\": 46.1,\n    \"humidity\": 68,\n    \"alertLevel\": \"danger\",\n    \"lat\": 43.6532,\n    \"lng\": -79.3832,\n    \"zone\": \"downtown\"\n  }\n]"
            },
            {
              "name": "Invalid Query",
              "status": "Bad Request",
              "code": 400,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"error\": \"Invalid date value\"\n}"
            }
          ]
        },
        {
          "name": "List Alerts Alias",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}://{{base_url}}/api/logs/alerts?limit=25&level=danger&zone=downtown&from=2026-05-26T00:00:00.000Z&to=2026-05-27T00:00:00.000Z",
              "protocol": "{{protocol}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "logs",
                "alerts"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "25",
                  "description": "Optional number of newest-first alerts to return."
                },
                {
                  "key": "level",
                  "value": "danger",
                  "description": "Optional alert level: safe, caution, danger, or extreme."
                },
                {
                  "key": "zone",
                  "value": "downtown",
                  "description": "Optional zone filter."
                },
                {
                  "key": "from",
                  "value": "2026-05-26T00:00:00.000Z",
                  "description": "Optional ISO 8601 start timestamp."
                },
                {
                  "key": "to",
                  "value": "2026-05-27T00:00:00.000Z",
                  "description": "Optional ISO 8601 end timestamp."
                }
              ]
            },
            "description": "Alias for /api/alerts. Returns the same newest-first alert log rows with the same optional filters."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "[\n  {\n    \"id\": 1,\n    \"timestamp\": \"2026-05-26T14:30:00.000Z\",\n    \"temperature\": 37.5,\n    \"humidex\": 46.1,\n    \"humidity\": 68,\n    \"alertLevel\": \"danger\",\n    \"lat\": 43.6532,\n    \"lng\": -79.3832,\n    \"zone\": \"downtown\"\n  }\n]"
            }
          ]
        }
      ]
    }
  ]
}
